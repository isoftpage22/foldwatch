# Railway → frontend service → Variables tab
# Set config file path to /apps/frontend/railway.json on that service first.
# Replace "foldwatch" with your BACKEND service name from the canvas if different.

NODE_ENV=production

INTERNAL_API_URL=http://${{foldwatch.RAILWAY_PRIVATE_DOMAIN}}:${{foldwatch.PORT}}

# If private networking fails, comment the line above and use:
# INTERNAL_API_URL=https://${{foldwatch.RAILWAY_PUBLIC_DOMAIN}}
