# Database (local MySQL)
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=fold_watch
DATABASE_USER=root
DATABASE_PASS=12345678

# Default crawl interval for new sources (5 | 15 | 30 minutes)
DEFAULT_CRAWL_INTERVAL_MINUTES=30

# AI Provider — pick one: gemini | claude | openai
AI_PROVIDER=gemini

# Gemini (default)
GEMINI_API_KEY=AIzaSyACXwRlZXX47yJU9Avf9zmMTB3K_GzeF3A
GEMINI_MODEL=gemini-2.5-flash

# Claude (optional)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Crawl settings
CRAWL_CONCURRENCY=3
MAX_AGENT_STEPS=15

# Mark agent_runs still "running" after this many ms as failed (default 2h). Used by /dashboard/crawl-status and GET /runs.
# AGENT_RUN_STALE_MS=7200000
