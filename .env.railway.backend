# Railway → backend GitHub service → Variables tab
# Railway scans repo-root .env.* files and can suggest these for one-click import.
# Replace MySQL with your database service name on the canvas if it is not "MySQL".
# Set GEMINI_API_KEY (or other AI keys) in the UI — do not commit real secrets.

NODE_ENV=production

DATABASE_HOST=${{MySQL.MYSQLHOST}}
DATABASE_PORT=${{MySQL.MYSQLPORT}}
DATABASE_NAME=${{MySQL.MYSQLDATABASE}}
DATABASE_USER=${{MySQL.MYSQLUSER}}
DATABASE_PASS=${{MySQL.MYSQLPASSWORD}}

AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

DEFAULT_CRAWL_INTERVAL_MINUTES=30
CRAWL_CONCURRENCY=3
MAX_AGENT_STEPS=15

# Playwright / Chromium in container (optional)
RAILWAY_SHM_SIZE_BYTES=268435456
